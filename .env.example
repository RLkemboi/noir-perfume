# Server port (default: 3001)
PORT=3001

# Firebase Admin SDK credentials (from your service account JSON)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com

# Firebase Client SDK (from your Firebase project settings)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Admin emails — comma-separated list of emails that auto-receive Admin role on first login.
# If not set, NO email gets automatic admin elevation (configure this before going live!).
# Example: ADMIN_EMAILS=you@yourdomain.com,backup@yourdomain.com
ADMIN_EMAILS=

# M-Pesa Daraja API (Safaricom)
# Leave blank to use sandbox/mock mode — real STK pushes require live credentials + a public callback URL.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Must be a publicly reachable HTTPS URL — use ngrok or a deployed server for local dev.
# Example: MPESA_CALLBACK_URL=https://your-server.com/api/payments/mpesa/callback
MPESA_CALLBACK_URL=
